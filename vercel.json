{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/"
        },
        "backend": {
            "entrypoint": "backend/api/index.py",
            "routePrefix": "/api"
        }
    },
    "rewrites": [
        { "source": "/api/(.*)", "destination": "backend/api/index.py" }
    ]
}