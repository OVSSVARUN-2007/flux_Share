{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/api"
        }
    },
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api/index" }
    ]
}